NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI chat (server-side only)
# First-level in-character replies are generated by Inworld.
INWORLD_API_KEY=your_inworld_api_key
INWORLD_WORKSPACE=greektimes
INWORLD_MODEL=auto

# The cleanup pass calls OpenAI directly. Set OPENAI_API_KEY to enable it; if
# unset, the raw first-level reply is shown to the user and the debug log marks
# the entry as "cleanup skipped".
OPENAI_API_KEY=your_openai_api_key
# Optional: model used for the cleanup call. Falls back to OPENAI_MODEL, then gpt-4o-mini.
# OPENAI_CLEANUP_MODEL=gpt-4o-mini
# Optional: single-line override for the cleanup prompt (use {characterName},
# {loyaltyLevel}, {chemistryLevel} as placeholders).
# CLEANUP_PROMPT=
